{
  "compilerOptions": {
    /* Base Options */
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2023"
    ],
    "outDir": "./dist",
    // "rootDir": "./src",
    "baseUrl": "./",
    /* Type Checking & Strictness */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true, // Essential for ignoring errors in node_modules
    /* Interop & Metadata */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "resolvePackageJsonExports": true,
    /* Build & Output */
    "sourceMap": true,
    "declaration": true,
    "incremental": true,
    "removeComments": true,
    "isolatedModules": true,
    /* Paths & Types */
    "typeRoots": [
      "./node_modules/@types"
    ],
    "types": [
      "node"
    ]
  },
  "deleteOutDir": true,
  "assets": [
    {
      "include": "src/assets/**/*",
      "watchAssets": true
    }
  ],
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "**/*.spec.ts",
    "dist"
  ]
}
